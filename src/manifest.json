{
  "manifest_version": 3,
  "name": "Revgain AI",
  "version": "1.0.0",
  "description": "Revgain AI - Intelligent revenue insights and automation",
  "permissions": [
    "storage",
    "sidePanel",
    "tabs",
    "cookies",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["loginMonitor.js"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Open Revgain AI"
  },
  "icons": {
    "16": "icons/rg_blue_logo.png",
    "48": "icons/rg_blue_logo.png",
    "128": "icons/rg_blue_logo.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["sidepanel.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
